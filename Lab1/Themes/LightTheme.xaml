<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Светлая тема: основные цвета интерфейса -->
    <SolidColorBrush x:Key="WindowBackground" Color="White"/>
    <SolidColorBrush x:Key="PanelBackground"  Color="#F5F5F5"/>
    <SolidColorBrush x:Key="TextPrimary"       Color="#212121"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#757575"/>
    <SolidColorBrush x:Key="Accent"            Color="#2196F3"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#CCCCCC"/>

</ResourceDictionary>
