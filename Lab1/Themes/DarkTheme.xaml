<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Тёмная тема: основные цвета интерфейса -->
    <SolidColorBrush x:Key="WindowBackground" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="PanelBackground"  Color="#2D2D2D"/>
    <SolidColorBrush x:Key="TextPrimary"       Color="#EEEEEE"/>
    <SolidColorBrush x:Key="TextSecondary"     Color="#AAAAAA"/>
    <SolidColorBrush x:Key="Accent"            Color="#42A5F5"/>
    <SolidColorBrush x:Key="BorderBrush"       Color="#444444"/>

</ResourceDictionary>
