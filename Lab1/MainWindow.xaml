<Window x:Class="Lab1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:system="clr-namespace:System;assembly=mscorlib"
        mc:Ignorable="d"
        Title="Менеджер привычек" Height="720" Width="1100"
        MinWidth="900" MinHeight="620"
        Background="White">

    <!-- DockPanel: основная компоновка окна (меню + тулбар + статус + контент) -->
    <DockPanel>

        <!-- ===== МЕНЮ ===== -->
        <Menu DockPanel.Dock="Top" FontSize="13" Background="#F5F5F5">
            <MenuItem Header="Файл">
                <MenuItem Header="Сохранить" Click="MenuSave_Click"/>
                <MenuItem Header="Загрузить" Click="MenuLoad_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Копировать" Click="MenuCopy_Click"/>
                <MenuItem Header="Вставить" Click="MenuPaste_Click"/>
            </MenuItem>
            <MenuItem Header="Вид">
                <MenuItem Header="Тёмная тема" Click="MenuDarkTheme_Click"/>
                <MenuItem Header="Светлая тема" Click="MenuLightTheme_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== ПАНЕЛЬ ИНСТРУМЕНТОВ ===== -->
        <ToolBarTray DockPanel.Dock="Top" Background="#EEEEEE">
            <ToolBar>
                <Button Content="💾 Сохранить" Click="MenuSave_Click" Padding="6,3"
                        ToolTip="Сохранить профиль"/>
                <Button Content="📂 Загрузить" Click="MenuLoad_Click" Padding="6,3"
                        ToolTip="Загрузить данные"/>
                <Separator/>
                <ToggleButton x:Name="toggleEditMode" Content="✏ Доп. панель"
                              Checked="ToggleEditMode_Checked"
                              Unchecked="ToggleEditMode_Unchecked"
                              Padding="6,3"
                              ToolTip="Показать/скрыть дополнительную панель"/>
                <Separator/>
                <Label Content="Продуктивность:" VerticalAlignment="Center" Padding="4,0"/>
                <RepeatButton Content="▲" Width="28" Height="24"
                              Click="RepeatUp_Click"
                              ToolTip="Увеличить продуктивность"/>
                <RepeatButton Content="▼" Width="28" Height="24"
                              Click="RepeatDown_Click"
                              ToolTip="Уменьшить продуктивность"/>
            </ToolBar>
        </ToolBarTray>

        <!-- ===== СТРОКА СОСТОЯНИЯ ===== -->
        <StatusBar DockPanel.Dock="Bottom" Background="#EEEEEE" Height="26">
            <StatusBarItem>
                <TextBlock x:Name="statusText" Text="Готово | Привычек: 0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="statusDate"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="statusUser" Text="Пользователь не задан"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ===== ОСНОВНОЙ КОНТЕНТ: TabControl с тремя вкладками ===== -->
        <TabControl x:Name="mainTabControl"
                    SelectionChanged="MainTabControl_SelectionChanged"
                    Margin="4">

            <!-- ═══════════════════════════════════════════════════════════
                 ВКЛАДКА 1: ЛИЧНЫЕ ДАННЫЕ
            ═══════════════════════════════════════════════════════════ -->
            <TabItem Header="  Личные данные  ">
                <DockPanel>

                    <!-- Скрытая дополнительная панель, управляемая ToggleButton -->
                    <Border x:Name="extraPanel"
                            DockPanel.Dock="Right"
                            Visibility="Collapsed"
                            Width="200"
                            BorderBrush="#2196F3"
                            BorderThickness="1"
                            Margin="4"
                            CornerRadius="4">
                        <StackPanel Margin="8">
                            <TextBlock Text="Дополнительные параметры"
                                       FontWeight="Bold" TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <Label Content="Ник:"/>
                            <TextBox x:Name="txtNickname" Padding="3" Margin="0,0,0,6"/>
                            <Label Content="Цель на месяц:"/>
                            <TextBox x:Name="txtGoal" Padding="3" Height="60"
                                     TextWrapping="Wrap" AcceptsReturn="True"/>
                        </StackPanel>
                    </Border>

                    <!-- ScrollViewer + WrapPanel для трёх GroupBox -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel Orientation="Horizontal" Margin="6">

                            <!-- GroupBox 1: Основная информация -->
                            <GroupBox Header="Основная информация"
                                      Margin="6" MinWidth="280" MaxWidth="340">
                                <StackPanel Margin="6">

                                    <Label Content="Имя:"/>
                                    <TextBox x:Name="txtFirstName" Padding="4,3" Margin="0,0,0,6"/>

                                    <Label Content="Фамилия:"/>
                                    <TextBox x:Name="txtLastName" Padding="4,3" Margin="0,0,0,6"/>

                                    <Label Content="Пароль:"/>
                                    <PasswordBox x:Name="pwdPassword" Padding="4,3" Margin="0,0,0,6"/>

                                    <Label Content="Дата рождения:"/>
                                    <DatePicker x:Name="dtpBirthDate" Margin="0,0,0,6"/>

                                    <Label Content="Аватар:"/>
                                    <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                            Width="90" Height="90"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,6" CornerRadius="4">
                                        <Image x:Name="imgAvatar" Stretch="UniformToFill"/>
                                    </Border>
                                    <Button Content="📷 Загрузить фото"
                                            Click="LoadAvatar_Click"
                                            HorizontalAlignment="Left"
                                            Padding="8,4"/>
                                </StackPanel>
                            </GroupBox>

                            <!-- GroupBox 2: Дополнительные данные -->
                            <GroupBox Header="Дополнительные данные"
                                      Margin="6" MinWidth="240" MaxWidth="300">
                                <StackPanel Margin="6">

                                    <Label Content="Образование:"/>
                                    <ComboBox x:Name="cmbEducation" Padding="4,3" Margin="0,0,0,10">
                                        <ComboBoxItem Content="Среднее"/>
                                        <ComboBoxItem Content="Среднее специальное"/>
                                        <ComboBoxItem Content="Высшее"/>
                                        <ComboBoxItem Content="Аспирантура"/>
                                    </ComboBox>

                                    <Label Content="Хобби (множественный выбор):"/>
                                    <ListBox x:Name="lstHobbies"
                                             SelectionMode="Multiple"
                                             Height="110"
                                             Margin="0,0,0,10"
                                             BorderBrush="#CCCCCC">
                                        <ListBoxItem Content="Спорт"/>
                                        <ListBoxItem Content="Чтение"/>
                                        <ListBoxItem Content="Музыка"/>
                                        <ListBoxItem Content="Программирование"/>
                                        <ListBoxItem Content="Путешествия"/>
                                    </ListBox>

                                    <!-- Вложенный GroupBox для RadioButton -->
                                    <GroupBox Header="Уровень активности" Padding="6">
                                        <StackPanel>
                                            <RadioButton x:Name="rbLow" Content="Низкий"
                                                         GroupName="ActivityLevel" Margin="0,3"/>
                                            <RadioButton x:Name="rbMedium" Content="Средний"
                                                         GroupName="ActivityLevel"
                                                         IsChecked="True" Margin="0,3"/>
                                            <RadioButton x:Name="rbHigh" Content="Высокий"
                                                         GroupName="ActivityLevel" Margin="0,3"/>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </GroupBox>

                            <!-- GroupBox 3: Настройки отображения -->
                            <GroupBox Header="Настройки отображения"
                                      Margin="6" MinWidth="240" MaxWidth="300">
                                <StackPanel Margin="6">

                                    <CheckBox x:Name="chkNotifications"
                                              Content="Получать уведомления"
                                              Margin="0,6"/>
                                    <CheckBox x:Name="chkPublicStats"
                                              Content="Показывать статистику публично"
                                              Margin="0,6"/>
                                    <CheckBox x:Name="chkAutoSave"
                                              Content="Автосохранение"
                                              IsChecked="True" Margin="0,6"/>
                                    <CheckBox x:Name="chkDarkMode"
                                              Content="Тёмный режим"
                                              Margin="0,6"
                                              Checked="ChkDarkMode_Checked"
                                              Unchecked="ChkDarkMode_Unchecked"/>

                                    <Separator Margin="0,10"/>

                                    <!-- DockPanel для кнопок управления -->
                                    <DockPanel LastChildFill="True" Margin="0,4">
                                        <Button Content="Сброс"
                                                Click="ResetProfile_Click"
                                                DockPanel.Dock="Right"
                                                Padding="10,5"
                                                Background="#f44336"
                                                Foreground="White"
                                                Margin="4,0,0,0"/>
                                        <Button Content="Сохранить"
                                                Click="SaveProfile_Click"
                                                Padding="10,5"
                                                Background="#4CAF50"
                                                Foreground="White"/>
                                    </DockPanel>

                                    <TextBlock x:Name="lblValidation"
                                               TextWrapping="Wrap"
                                               Foreground="Red"
                                               Margin="0,8,0,0"
                                               FontSize="12"/>
                                </StackPanel>
                            </GroupBox>

                        </WrapPanel>
                    </ScrollViewer>
                </DockPanel>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 ВКЛАДКА 2: ПРИВЫЧКИ
            ═══════════════════════════════════════════════════════════ -->
            <TabItem Header="  Привычки  ">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Левая подпанель: добавление, слайдеры, прогресс, заметки -->
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">

                        <!-- Блок добавления привычки -->
                        <Border BorderBrush="#2196F3" BorderThickness="1"
                                CornerRadius="4" Padding="8" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Добавить привычку"
                                           FontWeight="Bold" Margin="0,0,0,6"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtHabitName" Grid.Column="0"
                                             Padding="4,3" Margin="0,0,4,0"/>
                                    <TextBox x:Name="txtHabitTime" Grid.Column="1"
                                             Padding="4,3" Margin="0,0,4,0"/>
                                    <Button x:Name="btnAddHabit" Grid.Column="2"
                                            Content="Добавить"
                                            Click="AddHabit_Click"
                                            Background="#2196F3"
                                            Foreground="White"
                                            Padding="4,3"/>
                                </Grid>
                                <TextBlock Text="Название привычки                    Время (чч:мм)"
                                           FontSize="10" Foreground="Gray" Margin="0,3,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Слайдер: Продуктивность -->
                        <TextBlock Text="Продуктивность:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock x:Name="lblProductivity" DockPanel.Dock="Right"
                                       Width="45" TextAlignment="Right" Text="50%"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="slProductivity"
                                    Minimum="0" Maximum="100" Value="50"
                                    ValueChanged="SlProductivity_ValueChanged"
                                    TickFrequency="10" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- Слайдер: Удовлетворённость -->
                        <TextBlock Text="Удовлетворённость:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock x:Name="lblSatisfaction" DockPanel.Dock="Right"
                                       Width="45" TextAlignment="Right" Text="50%"
                                       VerticalAlignment="Center"/>
                            <Slider x:Name="slSatisfaction"
                                    Minimum="0" Maximum="100" Value="50"
                                    ValueChanged="SlSatisfaction_ValueChanged"
                                    TickFrequency="10" IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"/>
                        </DockPanel>

                        <!-- ProgressBar прогресса дня -->
                        <TextBlock Text="Прогресс дня:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <ProgressBar x:Name="pbDayProgress"
                                     Height="22" Minimum="0" Maximum="100" Value="50"
                                     Margin="0,0,0,10"/>

                        <!-- RichTextBox для заметок -->
                        <TextBlock Text="Заметки о привычках:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1">
                            <RichTextBox x:Name="rtbNotes" Height="140" Padding="4"/>
                        </Border>
                    </StackPanel>

                    <!-- Правая подпанель: Calendar + DataGrid -->
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="Выберите дату:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1"
                                HorizontalAlignment="Center" Margin="0,0,0,10">
                            <Calendar x:Name="calendar"
                                      SelectedDate="{x:Static system:DateTime.Today}"
                                      SelectedDatesChanged="Calendar_SelectedDatesChanged"/>
                        </Border>

                        <TextBlock Text="Список привычек:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="210">
                            <DataGrid x:Name="dgHabits"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      ItemsSource="{Binding Habits}"
                                      GridLinesVisibility="All"
                                      HeadersVisibility="Column"
                                      CellEditEnding="DgHabits_CellEditEnding">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Привычка"
                                                        Binding="{Binding Name}"
                                                        Width="*"/>
                                    <DataGridTextColumn Header="Время"
                                                        Binding="{Binding Time}"
                                                        Width="75"/>
                                    <DataGridCheckBoxColumn Header="Выполнено"
                                                            Binding="{Binding IsCompleted}"
                                                            Width="80"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </ScrollViewer>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════════════
                 ВКЛАДКА 3: СТАТИСТИКА
            ═══════════════════════════════════════════════════════════ -->
            <TabItem Header="  Статистика  ">
                <Grid Margin="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ListView: статистика по дням -->
                    <DockPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="История активности по дням:"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1">
                            <ListView x:Name="lvStatistics">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="Дата"
                                                        DisplayMemberBinding="{Binding Date, StringFormat=dd.MM.yyyy}"
                                                        Width="90"/>
                                        <GridViewColumn Header="Прод.%"
                                                        DisplayMemberBinding="{Binding Productivity}"
                                                        Width="58"/>
                                        <GridViewColumn Header="Удов.%"
                                                        DisplayMemberBinding="{Binding Satisfaction}"
                                                        Width="58"/>
                                        <GridViewColumn Header="Привычек"
                                                        DisplayMemberBinding="{Binding CompletedHabits}"
                                                        Width="68"/>
                                        <GridViewColumn Header="Прогресс"
                                                        DisplayMemberBinding="{Binding Progress}"
                                                        Width="68"/>
                                    </GridView>
                                </ListView.View>
                            </ListView>
                        </Border>
                    </DockPanel>

                    <!-- TreeView: иерархия категорий привычек -->
                    <DockPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="Категории привычек:"
                                   FontWeight="Bold" Margin="0,0,0,4"/>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1">
                            <TreeView x:Name="tvCategories">
                                <TreeViewItem Header="🏃 Здоровье" IsExpanded="True">
                                    <TreeViewItem Header="Спорт"/>
                                    <TreeViewItem Header="Правильное питание"/>
                                    <TreeViewItem Header="Здоровый сон"/>
                                </TreeViewItem>
                                <TreeViewItem Header="📚 Развитие" IsExpanded="True">
                                    <TreeViewItem Header="Чтение"/>
                                    <TreeViewItem Header="Обучение"/>
                                    <TreeViewItem Header="Медитация"/>
                                </TreeViewItem>
                                <TreeViewItem Header="💼 Работа">
                                    <TreeViewItem Header="Планирование задач"/>
                                    <TreeViewItem Header="Фокус-сессии"/>
                                    <TreeViewItem Header="Ревью прогресса"/>
                                </TreeViewItem>
                                <TreeViewItem Header="🤝 Социальное">
                                    <TreeViewItem Header="Общение с близкими"/>
                                    <TreeViewItem Header="Волонтёрство"/>
                                </TreeViewItem>
                            </TreeView>
                        </Border>
                    </DockPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
